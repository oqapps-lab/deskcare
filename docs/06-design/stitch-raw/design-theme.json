  "shared_rules": {
    "border_radius": {
      "cards": "3rem",
      "buttons_chips": "9999px",
      "inputs": "9999px"
    },
    "no_sharp_corners": true,
    "no_solid_1px_borders": true,
    "no_pure_black": true,
    "no_grey_shadows": true,
    "ghost_border_fallback": "outline_variant at 15% opacity",
    "ambient_shadow": {
      "color": "primary at 5-8% opacity",
      "blur": "32px+"
    },
    "glassmorphism": {
      "backdrop_blur": "20-24px",
      "surface_opacity": "60%"
    },
    "elevation_method": "tonal_layering",
    "dividers": "refraction gradient (transparent → outline_variant 20% → transparent)"
  },

